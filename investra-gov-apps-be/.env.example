# Flask
FLASK_APP=Wsgi.py
FLASK_ENV=development
SECRET_KEY=
JWT_EXPIRES_HOURS=12

# Database
POSTGRES_USER=investra
POSTGRES_PASSWORD=
POSTGRES_DB=investra_db
DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT_MS=30000
DB_LOCK_TIMEOUT_MS=5000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000
DB_APPLICATION_NAME=investra-api

# CORS (comma-separated origins; * only for local dev)
CORS_ORIGINS=*

# Superadmin bootstrap (used by GenerateSuperAdmin.py)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@investra.go.id
SUPERADMIN_FULL_NAME=Super Administrator
SUPERADMIN_PASSWORD=
