# =============================================================================
# INVESTRA Backend — Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production these values come from container orchestrator / secret manager.
# Anything blank here MUST be set before the API can start.
# =============================================================================

# -----------------------------------------------------------------------------
# Flask runtime
# -----------------------------------------------------------------------------
FLASK_APP=wsgi.py
# development | production
FLASK_ENV=development
# Random 32+ chars. Generate: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SECRET_KEY=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_EXPIRES_HOURS=12

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Compose builds DATABASE_URL from these parts. Override DATABASE_URL only if
# pointing the API at an external Postgres.
POSTGRES_USER=investra
POSTGRES_PASSWORD=
POSTGRES_DB=investra_db
# DATABASE_URL=postgresql://investra:<password>@db:5432/investra_db

# Pool tuning (sane defaults — leave commented unless you need to override)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# DB_STATEMENT_TIMEOUT_MS=30000
# DB_LOCK_TIMEOUT_MS=5000
# DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000
# DB_APPLICATION_NAME=investra-api

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated origins. Use `*` only for local development.
CORS_ORIGINS=http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=false

# -----------------------------------------------------------------------------
# Request limits
# -----------------------------------------------------------------------------
# 10 MB upload cap (in bytes)
MAX_CONTENT_LENGTH=10485760

# -----------------------------------------------------------------------------
# Security headers
# -----------------------------------------------------------------------------
# 1 year HSTS
HSTS_SECONDS=31536000

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
# Use Redis in production. `memory://` is fine for local-only.
RATELIMIT_STORAGE_URI=redis://redis:6379/0
