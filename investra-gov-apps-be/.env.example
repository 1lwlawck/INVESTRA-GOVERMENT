# Flask
FLASK_APP=Wsgi.py
FLASK_ENV=development
SECRET_KEY=replace_with_a_strong_secret
JWT_EXPIRES_HOURS=12

# Database
POSTGRES_USER=investra
POSTGRES_PASSWORD=replace_with_db_password
POSTGRES_DB=investra_db
DATABASE_URL=postgresql://investra:replace_with_db_password@localhost:5432/investra_db

# CORS (comma-separated origins; * only for local dev)
CORS_ORIGINS=*

# Superadmin bootstrap (used by GenerateSuperAdmin.py)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@investra.go.id
SUPERADMIN_FULL_NAME=Super Administrator
SUPERADMIN_PASSWORD=replace_with_superadmin_password
