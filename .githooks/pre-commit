#!/usr/bin/env bash

# react-doctor hook start
react_doctor_scan_staged_files() {
  if [ -x "./node_modules/.bin/react-doctor" ]; then
    "./node_modules/.bin/react-doctor" --staged --fail-on warning
    return
  fi

  if command -v react-doctor >/dev/null 2>&1; then
    react-doctor --staged --fail-on warning
    return
  fi

  if command -v pnpm >/dev/null 2>&1; then
    pnpm dlx react-doctor@latest --staged --fail-on warning
    return
  fi

  if command -v npx >/dev/null 2>&1; then
    npx --yes react-doctor@latest --staged --fail-on warning
    return
  fi

  printf '%s\n' "react-doctor: command not found; skipping staged scan."
}

react_doctor_output=$(mktemp "${TMPDIR:-/tmp}/react-doctor-hook.XXXXXX")
if react_doctor_scan_staged_files > "$react_doctor_output" 2>&1; then
  rm -f "$react_doctor_output"
else
  rm -f "$react_doctor_output"
  printf '%s\n' "React Doctor found staged regressions." "Run react-doctor --staged --fail-on warning to inspect." "Want them fixed? Ask your agent to run that command and resolve the findings." >&2
fi
# react-doctor hook end
# Pre-commit hook:
#   - BE: ruff on staged Python files
#   - FE: eslint on staged TS/TSX/JS/JSX files
# Skipped automatically when no relevant files in that area are staged.

set -e

repo_root="$(git rev-parse --show-toplevel)"
be_dir="$repo_root/investra-gov-apps-be"
fe_dir="$repo_root/investra-gov-apps-fe"

# ─── Backend (Python) ───────────────────────────────────────────────
staged_be_py=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^investra-gov-apps-be/.+\.py$' || true)

if [ -n "$staged_be_py" ]; then
  if [ -x "$be_dir/.venv/Scripts/ruff.exe" ]; then
    ruff_bin="$be_dir/.venv/Scripts/ruff.exe"
  elif [ -x "$be_dir/.venv/bin/ruff" ]; then
    ruff_bin="$be_dir/.venv/bin/ruff"
  elif command -v ruff >/dev/null 2>&1; then
    ruff_bin="ruff"
  else
    echo "[pre-commit] ruff not found. Install dev deps:"
    echo "  cd investra-gov-apps-be && pip install -e \".[dev]\""
    exit 1
  fi

  echo "[pre-commit] running ruff on staged BE files..."
  cd "$be_dir"
  echo "$staged_be_py" \
    | sed 's|^investra-gov-apps-be/||' \
    | xargs "$ruff_bin" check
  cd "$repo_root"
fi

# ─── Frontend (TS/JS) ────────────────────────────────────────────────
staged_fe_files=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^investra-gov-apps-fe/.+\.(ts|tsx|js|jsx)$' || true)

if [ -n "$staged_fe_files" ]; then
  if [ ! -d "$fe_dir/node_modules" ]; then
    echo "[pre-commit] FE node_modules not found. Install:"
    echo "  cd investra-gov-apps-fe && npm ci"
    exit 1
  fi

  echo "[pre-commit] running eslint on staged FE files..."
  cd "$fe_dir"

  relative=$(echo "$staged_fe_files" | sed 's|^investra-gov-apps-fe/||')
  # Pass file list to npx eslint via xargs so quoting is safe
  echo "$relative" | xargs npx --no-install eslint --max-warnings=0 --no-warn-ignored
  cd "$repo_root"
fi
